@page
@model WebAPP.Pages.Reservas.RecibidasModel
@{
    ViewData["Title"] = "Reservas recibidas";
}

<h1 class="h3 mb-4">Reservas recibidas</h1>

@if (!string.IsNullOrWhiteSpace(Model.Mensaje))
{
    <div class="alert alert-success">@Model.Mensaje</div>
}

@if (!string.IsNullOrWhiteSpace(Model.Error))
{
    <div class="alert alert-danger">@Model.Error</div>
}

@if (!Model.Reservas.Any())
{
    <div class="alert alert-info">Todavia no tienes solicitudes de reserva.</div>
}
else
{
    <div class="list-group">
        @foreach (var reserva in Model.Reservas)
        {
            <article class="list-group-item">
                <div class="d-flex flex-wrap justify-content-between gap-3">
                    <div>
                        <h2 class="h5 mb-1">@reserva.VehiculoNombre</h2>
                        <p class="text-muted mb-1">Cliente: @reserva.PersonaNombre</p>
                        <p class="mb-0">@reserva.FechaInicio:dd/MM/yyyy - @reserva.FechaFin:dd/MM/yyyy</p>
                    </div>
                    <div class="text-md-end">
                        <span class="badge text-bg-light">@reserva.Estado</span>
                        <p class="mb-2 mt-2">@reserva.PrecioTotal:C0</p>
                        @if (reserva.Estado == "PENDIENTE")
                        {
                            <form method="post" class="d-inline" asp-page-handler="Aceptar" asp-route-id="@reserva.Id">
                                <button class="btn btn-success btn-sm" type="submit">Aceptar</button>
                            </form>
                            <form method="post" class="d-inline" asp-page-handler="Rechazar" asp-route-id="@reserva.Id">
                                <button class="btn btn-outline-danger btn-sm" type="submit">Rechazar</button>
                            </form>
                        }
                        @if (reserva.ConversacionId.HasValue)
                        {
                            <a class="btn btn-primary btn-sm" asp-page="/Chat/Detalle" asp-route-id="@reserva.ConversacionId.Value">Abrir chat</a>
                        }
                    </div>
                </div>
            </article>
        }
    </div>
}
